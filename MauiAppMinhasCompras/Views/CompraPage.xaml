<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppMinhasCompras.Views.CompraPage"
             Title="Finalizar Compra">

    <ContentPage.Content>
        <VerticalStackLayout Padding="20" Spacing="15">
            <Label Text="Finalizar Compra" FontSize="20" HorizontalOptions="Center" />

            <Label Text="Total" />
            <Label x:Name="lbl_total" FontAttributes="Bold" />

            <Label Text="Forma de pagamento" />
            <Picker x:Name="picker_forma" Title="Escolha" SelectedIndexChanged="Picker_forma_SelectedIndexChanged">
                <Picker.Items>
                    <x:String>Cartão</x:String>
                    <x:String>Débito</x:String>
                    <x:String>Pix</x:String>
                </Picker.Items>
            </Picker>

            <Label Text="Desconto" />
            <Label x:Name="lbl_desconto" />

            <Label Text="Total a pagar" />
            <Label x:Name="lbl_total_final" FontAttributes="Bold" />

            <Button Text="Pagar" Clicked="BtnPagar_Clicked" />
        </VerticalStackLayout>
    </ContentPage.Content>
</ContentPage>